@page
@model Cnh_rapida.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-4">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2>Criar nova conta</h2>
            <hr />

            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <!-- Nome completo -->
            <div class="form-floating mb-3">
                <input asp-for="Input.NomeCompleto" class="form-control" placeholder="Nome completo" />
                <label asp-for="Input.NomeCompleto">Nome completo</label>
                <span asp-validation-for="Input.NomeCompleto" class="text-danger"></span>
            </div>

            <!-- Estado -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Estado" class="form-control" placeholder="Estado" />
                <label asp-for="Input.Estado">Estado</label>
                <span asp-validation-for="Input.Estado" class="text-danger"></span>
            </div>

            <!-- Data de nascimento -->
            <div class="form-floating mb-3">
                <input asp-for="Input.DataNascimento" type="date" class="form-control" />
                <label asp-for="Input.DataNascimento">Data de nascimento</label>
                <span asp-validation-for="Input.DataNascimento" class="text-danger"></span>
            </div>

            <!-- CPF -->
            <div class="form-floating mb-3">
                <input asp-for="Input.CPF" class="form-control" placeholder="CPF" />
                <label asp-for="Input.CPF">CPF</label>
                <span asp-validation-for="Input.CPF" class="text-danger"></span>
            </div>

            <!-- Email -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <!-- Password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Senha" />
                <label asp-for="Input.Password">Senha</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <!-- Confirm Password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Confirme a senha" />
                <label asp-for="Input.ConfirmPassword">Confirme a senha</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Registrar</button>
        </form>
    </div>

    <div class="col-md-6 col-md-offset-2">
        <section>
            <h3>Registrar usando outro serviço</h3>
            <hr />
            @{
                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <div>
                        <p>
                            Nenhum serviço externo de autenticação configurado.
                            <a href="https://go.microsoft.com/fwlink/?LinkID=532715">Saiba mais</a>.
                        </p>
                    </div>
                }
                else
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                        <div>
                            <p>
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-primary" name="provider" value="@provider.Name" title="Entrar usando @provider.DisplayName">
                                        @provider.DisplayName
                                    </button>
                                }
                            </p>
                        </div>
                    </form>
                }
            }
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
