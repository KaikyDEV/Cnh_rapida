@model List<Cnh_rapida.Models.AlunoCnhStatus>

@{
    ViewData["Title"] = "Validação de Exames";
}

<h2 class="mb-4">📋 Exames Pendentes</h2>

@if (!Model.Any())
{
    <div class="alert alert-success">
        Nenhum exame pendente 🎉
    </div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Aluno</th>
                <th>Exame Médico</th>
                <th>Psicotécnico</th>
                <th>Enviado em</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Usuario.NomeCompleto</td>

                    <td>
                        <a href="@item.CaminhoExameMedico" target="_blank" class="btn btn-outline-primary btn-sm">
                            Visualizar
                        </a>
                    </td>

                    <td>
                        <a href="@item.CaminhoPsicotecnico" target="_blank" class="btn btn-outline-primary btn-sm">
                            Visualizar
                        </a>
                    </td>

                    <td>
                        @item.DataEnvioExames?.ToString("dd/MM/yyyy HH:mm")
                    </td>
                    <td class="d-flex gap-2">
                        <form action="/Admin/Admin/AprovarExames/@item.Id" method="post">
                            <button type="submit" class="btn btn-success btn-sm">
                                Aprovar
                            </button>
                        </form>

                        <form action="/Admin/Admin/RejeitarExames/@item.Id" method="post">
                            <button type="submit" class="btn btn-danger btn-sm">
                                Rejeitar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
